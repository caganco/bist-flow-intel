DATABASE_URL=postgresql+asyncpg://flowuser:flowpass@localhost:5432/flow_intel
LOG_LEVEL=DEBUG
KAP_BASE_URL=https://www.kap.org.tr
KAP_RATE_LIMIT_RPS=2
KAP_TIMEOUT_S=10
KAP_USER_AGENT=flow-intel/0.1 (research)

# TSG (Ticaret Sicil Gazetesi) — 2captcha auto mode
# All three required for headless (browser-invisible) scraping.
# Without TWOCAPTCHA_API_KEY the scraper falls back to headful manual mode.
TWOCAPTCHA_API_KEY=your_key_here
TSG_USERNAME=your@email.com
TSG_PASSWORD=your_password
