DATABASE_URL=postgresql+asyncpg://flowuser:flowpass@localhost:5432/flow_intel
LOG_LEVEL=DEBUG
KAP_BASE_URL=https://www.kap.org.tr
KAP_RATE_LIMIT_RPS=2
KAP_TIMEOUT_S=10
KAP_USER_AGENT=flow-intel/0.1 (research)

# TSG (Ticaret Sicil Gazetesi) - semi-automatic scraping.
# The scraper opens a visible browser; you sign in and solve the login
# CAPTCHA by hand once, then the run proceeds automatically. No credentials
# are stored here. Optional Tesseract path override for gazette-PDF OCR:
# TESSERACT_CMD=/path/to/tesseract
